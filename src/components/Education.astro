---
import SchoolIcon from '../icons/School.astro';
---
<section class="container mx-auto animate-fade-in" id="Education">
  <h2 class="flex gap-x-2 text-2xl font-bold mb-7 text-white dark:text-neutral-800">
    <span data-translate="education.title">Educacion</span> <SchoolIcon class="size-6" />
  </h2>

  <ol class="flex flex-col sm:flex-row sm:justify-between items-start sm:items-baseline sm:gap-y-0 w-full">
    
    <li class="relative flex-1 w-full">
      <div class="flex items-start sm:block gap-x-4 sm:gap-x-0">
        <div class="flex items-center sm:h-full shrink-0 mt-1 sm:mt-0">
          <div class="z-10 flex items-center justify-center w-6 h-6 bg-violet-900/50 dark:bg-blue-100 rounded-full ring-0 sm:ring-8 ring-violet-900 dark:ring-blue-300 shrink-0">
            <svg class="w-2.5 h-2.5 text-violet-300 dark:text-blue-700" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
            </svg>
          </div>
          <div class="hidden sm:flex w-full bg-violet-800/50 dark:bg-blue-300 h-0.5"></div>
        </div>

        <div class="flex flex-col sm:block pl-0 sm:mt-3 sm:pe-8">
          <h3 class="text-lg font-semibold text-white dark:text-black leading-tight">Universidad Internacional de La Rioja</h3>
          <time class="block mt-1 mb-2 sm:mt-0 sm:mb-3 text-sm font-medium leading-none text-violet-300 dark:text-blue-600 education-fimedatedip" data-translate="education.fimedatedip"></time>
          <p class="text-base font-normal text-gray-300 dark:text-gray-700" data-translate="education.fimetitledip">MAESTRÍA EN INGENIERÍA DE SOFTWARE Y SISTEMAS INFORMATICOS</p>
        </div>
      </div>
      <hr class="sm:hidden w-full border-violet-800/30 dark:border-blue-300/50 my-6" />
    </li>


    <li class="relative flex-1 w-full">
      <div class="flex items-start sm:block gap-x-4 sm:gap-x-0">
        <div class="flex items-center sm:h-full shrink-0 mt-1 sm:mt-0">
          <div class="z-10 flex items-center justify-center w-6 h-6 bg-violet-900/50 dark:bg-blue-100 rounded-full ring-0 sm:ring-8 ring-violet-900 dark:ring-blue-300 shrink-0">
            <svg class="w-2.5 h-2.5 text-violet-300 dark:text-blue-700" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
            </svg>
          </div>
          <div class="hidden sm:flex w-full bg-violet-800/50 dark:bg-blue-300 h-0.5"></div>
        </div>

        <div class="flex flex-col sm:block pl-0 sm:mt-3 sm:pe-8">
          <h3 class="text-lg font-semibold text-white dark:text-black leading-tight">Facultad de Ingeniería en Mecánica y Eléctrica</h3>
          <time class="block mt-1 mb-2 sm:mt-0 sm:mb-3 text-sm font-medium leading-none text-violet-300 dark:text-blue-600">2016 - 2023</time>
          <p class="text-base font-normal text-gray-300 dark:text-gray-700" data-translate="education.fimetitle">INGENIERO EN TECNOLOGÍA DE SOFTWARE (TITULADO)</p>
        </div>
      </div>
      <hr class="sm:hidden w-full border-violet-800/30 dark:border-blue-300/50 my-6" />
    </li>

    <li class="relative flex-1 w-full">
      <div class="flex items-start sm:block gap-x-4 sm:gap-x-0">
        <div class="flex items-center sm:h-full shrink-0 mt-1 sm:mt-0"> 
          <div class="z-10 flex items-center justify-center w-6 h-6 bg-violet-900/50 dark:bg-blue-100 rounded-full ring-0 sm:ring-8 ring-violet-900 dark:ring-blue-300 shrink-0">
            <svg class="w-2.5 h-2.5 text-violet-300 dark:text-blue-700" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
            </svg>
          </div>
          <div class="hidden sm:flex w-full bg-violet-800/50 dark:bg-blue-300 h-0.5"></div>
        </div>

        <div class="flex flex-col sm:block pl-0 sm:mt-3 sm:pe-8">
          <h3 class="text-lg font-semibold text-white dark:text-black leading-tight">Escuela Industrial y Preparatoria Técnica “Álvaro Obregón”</h3>
          <time class="block mt-1 mb-2 sm:mt-0 sm:mb-3 text-sm font-medium leading-none text-violet-300 dark:text-blue-600">2012 - 2015</time>
          <p class="text-base font-normal text-gray-300 dark:text-gray-700" data-translate="education.eiao">BACHILLER TÉCNICO EN PROGRAMACIÓN WEB</p>
        </div>
      </div>
    </li>
  </ol>
</section>