---
import LanguagesContent from "./Languages.astro"
import FrameworksContent from "./Frameworks.astro"
import ToolsTecContent from "./ToolsTec.astro"
import PersonalSkillsContent from "./PersonalSkills.astro"
import ToolsIcon from '../icons/Tools.astro';
---

<h2 class="flex gap-x-2 text-2xl font-bold mb-7 text-white dark:text-neutral-800" id="educationTitle" > 
    <span data-translate="skillsmenu.skills"></span><ToolsIcon class="size-6" />
</h2>

<div class="w-full bg-slate-900/50 border border-violet-700/50 rounded-lg shadow-sm dark:bg-gray-200 dark:border-blue-700/50">
    
    <ul class="flex flex-wrap text-sm font-medium text-center border-b border-violet-700/50 rounded-t-lg bg-slate-950/50 dark:bg-gray-300 dark:border-blue-700/50" id="defaultTab" data-tabs-toggle="#defaultTabContent" role="tablist">
      <li class="me-2">
        <button id="languages-tab" data-tabs-target="#languages" type="button" role="tab" aria-controls="languages" aria-selected="true" class="tab-button inline-block p-4 rounded-ss-lg transition-all duration-300">
            <span data-translate="skillsmenu.languages"></span>
        </button>
      </li>
      <li class="me-2">
        <button id="frameworks-tab" data-tabs-target="#frameworks" type="button" role="tab" aria-controls="frameworks" aria-selected="false" class="tab-button inline-block p-4 transition-all duration-300">
            Frameworks
        </button>
      </li>
      <li class="me-2">
        <button id="tools-tab" data-tabs-target="#tools" type="button" role="tab" aria-controls="tools" aria-selected="false" class="tab-button inline-block p-4 transition-all duration-300">
            <span data-translate="skillsmenu.toolstec"></span>
        </button>
      </li>
      <li class="me-2">
        <button id="personal-tab" data-tabs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="false" class="tab-button inline-block p-4 rounded-se-lg transition-all duration-300">
            <span data-translate="skillsmenu.pskills"></span>
        </button>
      </li>
    </ul>
    
    <div id="defaultTabContent">
        <div class="hidden p-4 rounded-b-lg bg-transparent" id="languages" role="tabpanel" aria-labelledby="languages-tab">
            <LanguagesContent />
        </div>
        <div class="hidden p-4 rounded-b-lg bg-transparent" id="frameworks" role="tabpanel" aria-labelledby="frameworks-tab">
            <FrameworksContent />
        </div>
        <div class="hidden p-4 rounded-b-lg bg-transparent" id="tools" role="tabpanel" aria-labelledby="tools-tab">
            <ToolsTecContent />
        </div>
        <div class="hidden p-4 rounded-b-lg bg-transparent" id="personal" role="tabpanel" aria-labelledby="personal-tab">
            <PersonalSkillsContent />
        </div>
    </div>
</div>

<style>
  /* MODO OSCURO  */
  .tab-button[aria-selected="true"] {
    color: #ffffff;
    background-color: #4c1d95; 
  }
  .tab-button[aria-selected="false"] {
    color: #a78bfa; 
    background-color: transparent;
  }
  .tab-button[aria-selected="false"]:hover {
    background-color: #5b21b6;
    color: #ffffff;
  }

  /* MODO CLARO  */
  :global(.dark) .tab-button[aria-selected="true"] {
    color: #000000;
    background-color: #bfdbfe; 
  }
  :global(.dark) .tab-button[aria-selected="false"] {
    color: #475569; 
    background-color: transparent;
  }
  :global(.dark) .tab-button[aria-selected="false"]:hover {
    background-color: #dbeafe;
    color: #1d4ed8;
  }
</style>

<script>
  // Agrega el evento para manejar el cambio de pestañas
  document.addEventListener('DOMContentLoaded', () => {
    const tabButtons = document.querySelectorAll('.tab-button');
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        tabButtons.forEach(btn => btn.setAttribute('aria-selected', 'false'));
        button.setAttribute('aria-selected', 'true');
      });
    });
  });
</script>